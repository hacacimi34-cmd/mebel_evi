<div class="product-card">
  <div class="product-img-wrap">
    <a href="/products/<%= product.slug %>">
      <% if(product.mainImage) { %>
        <img src="<%= product.mainImage %>" alt="Mebel" class="product-img">
      <% } else { %>
        <div class="no-img"><i class="fas fa-couch"></i></div>
      <% } %>
    </a>
    <% if(product.discountPrice) { %>
      <span class="badge badge-sale"><%=t.sale%></span>
    <% } %>
    <% if(product.featured) { %>
      <span class="badge badge-featured"><%= lang === 'az' ? 'Seçilmiş' : 'Featured' %></span>
    <% } %>
    <div class="product-actions">
      <button class="action-btn add-to-cart-btn"
        data-id="<%= product._id %>"
        title="<%=t.add_to_cart%>">
        <i class="fas fa-shopping-bag"></i>
      </button>
      <a href="/products/<%= product.slug %>" class="action-btn" title="<%= lang === 'az' ? 'Bax' : 'View' %>">
        <i class="fas fa-eye"></i>
      </a>
    </div>
  </div>
  <div class="product-info">
    <span class="product-category"><%= product.category ? (product.category[lang] || product.category.az) : '' %></span>
    <h3><a href="/products/<%= product.slug %>"><%= product.name[lang] || product.name.az %></a></h3>
    <div class="product-price">
      <% if(product.discountPrice) { %>
        <span class="price-new"><%= product.discountPrice %> ₼</span>
        <span class="price-old"><%= product.price %> ₼</span>
      <% } else { %>
        <span class="price-new"><%= product.price %> ₼</span>
      <% } %>
    </div>
  </div>
</div>
